# ============================================================
# AdapterAI — .env.example
#
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#
# The .env file is injected into the backend container at
# runtime by docker-compose (env_file: - .env).
# ============================================================

# ── LLM Providers ────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Web Search ───────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Cloudflare AI Workers (embeddings) ───────────────────────
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ── Supabase Storage ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
SUPABASE_BUCKET=ChatbotFiles

# ── Pinecone Vector Store ────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=adapterai-index

# ── PostgreSQL  (Docker service name used as host) ───────────
# These are passed directly to Docker; override here if needed
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=app_db
POSTGRES_PORT=5432
# Full DSN is auto-constructed in docker-compose.yml:
#   postgresql://postgres:password@postgres:5432/app_db

# ── Redis  (Docker service name used as host) ────────────────
REDIS_PORT=6379
# Full URL is auto-constructed in docker-compose.yml:
#   redis://redis:6379

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_strong_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINS=60

# ── pgAdmin UI ───────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ── LangSmith Tracing (optional) ─────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=AdapterAI
